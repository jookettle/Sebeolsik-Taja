{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "3-set-keyboard-practice",
	"compatibility_date": "2026-04-06",
	"compatibility_flags": [
		"nodejs_als"
	],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"workers_dev": true,
	"preview_urls": true,
	"routes": [
		{ "pattern": "taja.ai.ai.kr", "custom_domain": true }
	]
}
